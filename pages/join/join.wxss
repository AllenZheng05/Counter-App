/* pages/join/join.wxss */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 40rpx;
  background-color: #f5f5f5;
}

/* Header 区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 60rpx;
}

.icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999999;
}

/* 表单区域 */
.form-section {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

/* 邀请码输入框 */
.code-input-wrapper {
  background-color: #ffffff;
  border: 3rpx solid #1a1a2e;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
}

.code-input {
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
  letter-spacing: 12rpx;
  color: #1a1a2e;
}

.code-display {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.code-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #1a1a2e;
  letter-spacing: 16rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 加入按钮 */
.action-section {
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}

.btn-join {
  width: 100%;
  height: 100rpx;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 16rpx;
}

/* 提示文字 */
.tips {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 32rpx;
  background-color: #f0f4ff;
  border-radius: 16rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

/* 没有邀请码 */
.no-code-section {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  gap: 12rpx;
}

.no-code-text {
  font-size: 28rpx;
  color: #999999;
}

.no-code-link {
  font-size: 28rpx;
  color: #1a1a2e;
  font-weight: 600;
  text-decoration: underline;
}