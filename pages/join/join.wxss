/* pages/join/join.wxss 商务深色统一版 */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 30rpx;
  background-color: #121826;
  box-sizing: border-box;
}

/* 顶部头部区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0 45rpx;
}

/* 统一图片样式 */
.house-img{
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #F1F5F9;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #94A3B8;
}

/* 表单整体 */
.form-section {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 统一商务卡片样式 */
.form-item {
  margin-bottom: 26rpx;
}
.card {
  background-color: #1E293B;
  border-radius: 14rpx;
  padding: 28rpx;
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.18);
}

.form-label {
  font-size: 27rpx;
  font-weight: 600;
  color: #E2E8F0;
  margin-bottom: 16rpx;
}

/* 邀请码输入框 */
.code-input-wrapper {
  background-color: #273444;
  border: 2rpx solid #334155;
  border-radius: 10rpx;
  padding: 20rpx 24rpx;
}

.code-input {
  font-size: 44rpx;
  font-weight: bold;
  text-align: center;
  letter-spacing: 12rpx;
  color: #F1F5F9;
}

.code-input::placeholder {
  color: #64748B;
  letter-spacing: 2rpx;
}

.code-display {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.code-text {
  font-size: 52rpx;
  font-weight: bold;
  color: #3B82F6;
  letter-spacing: 16rpx;
}

/* 加入按钮 */
.action-section {
  margin-top: 40rpx;
  margin-bottom: 30rpx;
}

.btn-primary {
  width: 100%;
  height: 94rpx;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 14rpx;
  background: linear-gradient(135deg,#2563EB,#1D4ED8);
  color: #ffffff;
  border: none;
  transition: all 0.2s ease;
}
.btn-primary::after{
  border: none;
}
.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.92;
}

/* 提示文字 */
.tips {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 24rpx;
  background-color: rgba(30, 41, 59, 0.6);
  border-radius: 14rpx;
}
.tip-text {
  font-size: 23rpx;
  color: #94A3B8;
  line-height: 1.5;
}

/* 没有邀请码 */
.no-code-section {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  gap: 12rpx;
}
.no-code-text {
  font-size: 28rpx;
  color: #94A3B8;
}
.no-code-link {
  font-size: 28rpx;
  color: #3B82F6;
  font-weight: 600;
}