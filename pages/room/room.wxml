<!--pages/room/room.wxml-->
<view class="container">
  <!-- 广告位 -->
  <view class="ad-banner-wrapper">
    <view class="custom-banner" wx:if="{{showCustomBanner}}">
      <text class="custom-banner-text">禁止赌博</text>
    </view>
    <ad wx:else unit-id="your-ad-unit-id" ad-type="banner" bindload="onAdLoad" binderror="onAdError"></ad>
  </view>

<!-- 顶部房间信息 → 新版排版 -->
<view class="room-header">
  <!-- 房间名称（居中） -->
  <view class="room-name">{{roomName}}</view>
  <!-- 第二行：左侧房间码 + 右侧离开按钮 -->
  <view class="room-bottom-row">
    <view class="room-code" bindtap="copyInviteCode">
      <text>房间号：{{inviteCode}}</text>
      <text class="copy-icon">📋</text>
    </view>
    <!-- 纯文字离开按钮 → 无椭圆、无图标 -->
    <text class="text-leave-btn" bindtap="leaveRoom">离开房间</text>
  </view>
</view>

  <!-- 计分表格区域 -->
  <view class="score-table-section">
    <!-- 表格容器 -->
    <view class="table-wrapper">
      <view class="score-table">
        <!-- 表头：玩家名称行 -->
        <view class="table-row header-row">
          <!-- 左上角格子 -->
          <view class="table-cell corner-cell">
            <view class="corner-top"><text class="corner-label">玩家</text></view>
            <view class="corner-bottom"><text class="corner-label">局数</text></view>
          </view>
          <view
            class="table-cell player-name-cell"
            wx:for="{{players}}"
            wx:key="id"
            wx:for-index="pIndex"
          >
            <view class="player-name-wrapper">
              <text class="player-name" bindtap="showEditPlayerName" data-index="{{pIndex}}" data-own="{{item.userId === currentUserId && currentUserId}}">
                {{item.name}}
              </text>
            </view>
          </view>
          <view class="table-cell action-column-header">
            <text>操作</text>
          </view>
        </view>

        <!-- 数据行：每一局的分数 -->
        <view 
          class="table-row data-row" 
          wx:for="{{scores}}" 
          wx:key="roundIndex"
          wx:for-index="roundIndex"
        >
          <view class="table-cell round-label-cell">
            <text>{{roundIndex + 1}}</text>
          </view>
          <view
            class="table-cell score-cell"
            wx:for="{{players}}"
            wx:key="id"
            wx:for-index="pIndex"
          >
            <view class="score-cell-inner" bindtap="showEditScore" data-roundindex="{{roundIndex}}" data-playerindex="{{pIndex}}">
              <text class="score-value {{scoreClassList[roundIndex + '-' + pIndex]}}">{{scoreValues[roundIndex + '-' + pIndex]}}</text>
            </view>
          </view>

          <view class="table-cell action-cell">
            <button 
              class="clear-round-btn" 
              bindtap="clearRound" 
              data-roundindex="{{roundIndex}}"
              wx:if="{{isCreator}}"
            >
              🗑️
            </button>
          </view>
        </view>

        <!-- 总分行 -->
        <view class="table-row total-row">
          <view class="table-cell row-label total-label">
            <text>总分</text>
          </view>
          <view
            class="table-cell total-cell"
            wx:for="{{players}}"
            wx:key="id"
            wx:for-index="pIndex"
          >
            <view class="total-cell-content">
              <text class="rank-badge">{{rankList[pIndex]}}</text>
              <text class="total-value {{totalClassList[pIndex]}}">{{totalDisplayList[pIndex]}}</text>
            </view>
          </view>
          <view class="table-cell action-cell total-action-cell">
            <text class="total-action-text"></text>
          </view>
        </view>
      </view>

      <!-- 加载状态 -->
      <view class="loading-state" wx:if="{{isLoading}}">
        <text class="loading-icon">⏳</text>
        <text class="loading-text">加载中...</text>
      </view>
      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!isLoading && players.length === 0}}">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无玩家，请先添加玩家</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮区域 -->
  <view class="action-bar">
    <view class="action-row">
      <button class="action-btn add-round-btn" bindtap="addRound" wx:if="{{isCreator}}">
        <text class="btn-icon">➕</text>
        <text>加局</text>
      </button>
      <button class="action-btn remove-round-btn" bindtap="removeRound" wx:if="{{isCreator && scores.length > 0}}">
        <text class="btn-icon">➖</text>
        <text>减局</text>
      </button>
      <button class="action-btn reset-btn" bindtap="resetAllScores" wx:if="{{isCreator}}">
        <text class="btn-icon">🔄</text>
        <text>重置</text>
      </button>
    </view>
  </view>

  <!-- 编辑弹窗 -->
  <view class="modal-overlay" wx:if="{{showEditModal}}" bindtap="hideEditModal">
    <view class="modal-content card" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title" wx:if="{{editType === 'playerName'}}">修改玩家名称</text>
        <text class="modal-title" wx:else>修改分数</text>
        <button class="close-btn" bindtap="hideEditModal">✕</button>
      </view>

      <view class="modal-body">
        <input 
          class="edit-input" 
          type="text"
          wx:if="{{editType === 'playerName'}}"
          placeholder="请输入玩家名称"
          value="{{editValue}}"
          bindinput="onEditInput"
          focus
        />
        <view wx:else class="score-edit-wrapper">
          <view class="score-sign-btns">
            <view 
              class="sign-btn {{scoreSign === '+' ? 'active' : ''}}" 
              data-sign="+"
              bindtap="toggleScoreSign"
            >+</view>
            <view 
              class="sign-btn {{scoreSign === '-' ? 'active' : ''}}" 
              data-sign="-"
              bindtap="toggleScoreSign"
            >-</view>
          </view>
          <input 
            class="edit-input score-input" 
            type="number"
            placeholder="请输入分数"
            value="{{editValue}}"
            bindinput="onEditInput"
            focus
          />
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideEditModal">取消</button>
        <button class="btn-primary" bindtap="submitEdit">确认</button>
      </view>
    </view>
  </view>
</view>