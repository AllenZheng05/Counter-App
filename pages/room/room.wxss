/* pages/room/room.wxss */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 200rpx;
  background-color: #f5f5f5;
}

/* 房间头部 */
.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.room-info {
  flex: 1;
}

.room-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.room-code {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666666;
}

.copy-icon {
  margin-left: 8rpx;
  font-size: 28rpx;
}

.room-actions {
  display: flex;
  gap: 16rpx;
}

.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  background: none;
  border: none;
  font-size: 40rpx;
  padding: 0;
  line-height: 1;
}

/* 计分表格区域 */
.score-table-section {
  flex: 1;
  margin-bottom: 24rpx;
}

.table-wrapper {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 表格样式 */
.score-table {
  display: flex;
  flex-direction: column;
}

.table-row {
  display: flex;
  border-bottom: 2rpx solid #f0f0f0;
}

.table-row:last-child {
  border-bottom: none;
}

.table-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 16rpx;
  min-height: 88rpx;
}

/* 行标签列 */
.row-label {
  width: 140rpx;
  min-width: 140rpx;
  background-color: #f8f9fa;
  font-size: 26rpx;
  font-weight: 600;
  color: #666666;
  border-right: 2rpx solid #f0f0f0;
}

.round-label {
  background-color: #e8f4fd;
  color: #1a73e8;
  font-weight: 600;
}

.total-label {
  background-color: #fff8e1;
  color: #f57f17;
  font-weight: 700;
  font-size: 30rpx;
}

/* 玩家名称列 */
.player-name-cell {
  flex: 1;
  padding: 16rpx;
  background-color: #e3f2fd;
  border-right: 2rpx solid #f0f0f0;
}

.player-name-cell:last-child {
  border-right: none;
}

.player-name-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 100%;
}

.player-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  text-align: center;
  flex: 1;
  cursor: pointer;
}

.player-name:active {
  opacity: 0.7;
}

.delete-player-btn {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  color: #999999;
  font-size: 28rpx;
  padding: 0;
  line-height: 1;
  flex-shrink: 0;
}

/* 分数单元格 */
.score-cell {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 2rpx solid #f0f0f0;
  transition: background-color 0.2s;
  position: relative;
}

.score-cell:last-child {
  border-right: none;
}

.score-cell-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
  transition: background-color 0.2s;
}

.score-cell-inner:active {
  background-color: #f0f0f0;
}

.score-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.score-cell.positive .score-value {
  color: #27ae60;
}

.score-cell.negative .score-value {
  color: #e74c3c;
}

/* 正负号切换按钮 */
.score-sign-toggle {
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.06);
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  color: #999;
  cursor: pointer;
  transition: all 0.15s;
}

.score-sign-toggle:active {
  background-color: rgba(0, 0, 0, 0.15);
  transform: translateY(-50%) scale(0.92);
}

.score-sign-toggle.positive {
  color: #27ae60;
  background-color: rgba(39, 174, 96, 0.12);
}

.score-sign-toggle.negative {
  color: #e74c3c;
  background-color: rgba(231, 76, 60, 0.12);
}

/* 总分行 */
.total-row {
  background-color: #fff8e1;
}

.total-cell {
  flex: 1;
  border-right: 2rpx solid #f0f0f0;
}

.total-cell:last-child {
  border-right: none;
}

.total-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.total-value.positive {
  color: #27ae60;
}

.total-value.negative {
  color: #e74c3c;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

/* 操作按钮区域 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  background-color: #f5f5f5;
  color: #333333;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn:active {
  background-color: #e0e0e0;
}

.add-round-btn {
  background-color: #1a1a2e;
  color: #ffffff;
}

.add-round-btn:active {
  background-color: #16213e;
}

.add-player-btn {
  background-color: #3498db;
  color: #ffffff;
}

.add-player-btn:active {
  background-color: #2980b9;
}

.reset-btn {
  background-color: #e74c3c;
  color: #ffffff;
}

.reset-btn:active {
  background-color: #c0392b;
}

.btn-icon {
  font-size: 36rpx;
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
  padding: 40rpx;
}

.modal-content {
  width: 100%;
  max-width: 500rpx;
  padding: 0;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  color: #999999;
  font-size: 36rpx;
  padding: 0;
  line-height: 1;
}

.modal-body {
  padding: 0 32rpx 32rpx;
}

.edit-input {
  width: 100%;
  height: 88rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1a1a2e;
}

/* 分数编辑包装器 */
.score-edit-wrapper {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 正负号按钮 */
.score-sign-btns {
  display: flex;
  gap: 16rpx;
}

.sign-btn {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #666666;
}

.sign-btn.active {
  background-color: #1a1a2e;
  color: #ffffff;
}

/* 分数输入框 */
.score-input {
  width: 100%;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx 32rpx;
}

.modal-footer button {
  flex: 1;
  height: 80rpx;
}