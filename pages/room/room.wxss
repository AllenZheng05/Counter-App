/* pages/room/room.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 140rpx;
  background-color: #121826;
}

/* 广告位 */
.ad-banner-wrapper {
  width: 100%;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.custom-banner {
  width: 100%;
  height: 80rpx;
  /* 商务渐变蓝黑 */
  background: linear-gradient(135deg, #1E293B, #0F172A);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.custom-banner-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 4rpx;
}

/* 房间头部 */
.room-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 24rpx;
  background-color: #1E293B;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

/* 居中大号房间名 最醒目 */
.room-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #F1F5F9;
  text-align: center;
  margin: 0;
  letter-spacing: 2rpx;
}

/* 第二行：房间号居中展示 */
.room-bottom-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.room-code {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #94A3B8;
  white-space: nowrap;
}

.copy-icon {
  margin-left: 10rpx;
  font-size: 30rpx;
}

/* 右侧离开文字按钮 简约精致 */
.text-leave-btn {
  font-size: 28rpx;
  color: #EF4444;
  font-weight: 600;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}
.text-leave-btn:active {
  background-color: rgba(239, 68, 68, 0.12);
  opacity: 1;
}

.room-actions {
  display: none;
}
.icon-btn {
  display: none;
}
.icon-btn:active {
  background: #334155;
}

/* ====================== */
/* 计分表格区域 */
.score-table-section {
  flex: 1;
  margin-bottom: 24rpx;
}

.table-wrapper {
  background-color: #1E293B;
  border-radius: 16rpx;
  overflow-x: auto;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

/* 表格样式 */
.score-table {
  display: flex;
  flex-direction: column;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #273444;
}

.table-row:last-child {
  border-bottom: none;
}

.table-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 12rpx;
  min-height: 80rpx;
  box-sizing: border-box;
  color: #F1F5F9;
}

/* 行标签列 */
.row-label {
  width: 90rpx;
  min-width: 90rpx;
  max-width: 90rpx;
  flex-shrink: 0;
  flex-grow: 0;
  background-color: #273444;
  font-size: 24rpx;
  font-weight: 600;
  color: #CBD5E1;
  border-right: 1rpx solid #334155;
}

/* 左上角格子 */
.corner-cell {
  width: 90rpx;
  min-width: 90rpx;
  max-width: 90rpx;
  height: 80rpx;
  padding: 0;
  flex-shrink: 0;
  flex-grow: 0;
  flex-direction: column;
  justify-content: flex-start;
  align-items: stretch;
  background-color: #273444;
  border-right: 1rpx solid #334155;
  overflow: hidden;
}

.corner-top {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 10rpx;
  border-bottom: 1rpx solid #334155;
  background-color: #2D3B4F;
}

.corner-bottom {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 10rpx;
  background-color: #2D3B4F;
}

.corner-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #E2E8F0;
}

/* 局数标签格子 */
.round-label-cell {
  width: 90rpx;
  min-width: 90rpx;
  max-width: 90rpx;
  flex-shrink: 0;
  flex-grow: 0;
  background-color: #2D3B4F;
  font-size: 26rpx;
  font-weight: 600;
  color: #E2E8F0;
  border-right: 1rpx solid #334155;
}

.total-label {
  background-color: #3D2C1F;
  color: #FBBF24;
  font-weight: 700;
  font-size: 30rpx;
}

/* 玩家名称列 */
.player-name-cell {
  width: 160rpx;
  min-width: 160rpx;
  max-width: 160rpx;
  flex-shrink: 0;
  flex-grow: 0;
  padding: 16rpx;
  background-color: #2D3B4F;
  border-right: 1rpx solid #334155;
}

.player-name-cell:last-child {
  border-right: none;
}

.player-name-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.player-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #F1F5F9;
  text-align: center;
  flex: 1;
  cursor: pointer;
}

.player-name:active {
  opacity: 0.7;
}


/* 操作列 */
.action-column-header {
  width: 90rpx;
  min-width: 90rpx;
  max-width: 90rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #94A3B8;
  font-weight: 600;
  background-color: #273444;
  border-left: 1rpx solid #334155;
}

.action-cell {
  width: 90rpx;
  min-width: 90rpx;
  max-width: 90rpx;
  flex-shrink: 0;
  padding: 8rpx;
  background-color: #273444;
  border-left: 1rpx solid #334155;
}

.clear-round-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  font-size: 36rpx;
  padding: 0;
  line-height: 1;
  border-radius: 50%;
  transition: all 0.15s;
  color: #EF4444;
}

.clear-round-btn:active {
  background-color: rgba(239, 68, 68, 0.15);
  transform: scale(0.92);
}

.total-action-cell {
  background-color: #3D2C1F;
  border-left: 1rpx solid #334155;
}

.total-action-text {
  font-size: 0;
}

/* 分数单元格 */
.score-cell {
  width: 160rpx;
  min-width: 160rpx;
  max-width: 160rpx;
  flex-shrink: 0;
  flex-grow: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #334155;
  transition: background-color 0.2s;
  background-color: #1E293B;
}

.score-cell:last-child {
  border-right: none;
}

.score-cell-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  cursor: pointer;
  padding: 12rpx 8rpx 6rpx;
  border-radius: 8rpx;
  transition: background-color 0.2s;
}

.score-cell-inner:active {
  background-color: #273444;
}

.score-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #F1F5F9;
}

.score-cell.positive .score-value {
  color: #10B981;
}

.score-cell.negative .score-value {
  color: #EF4444;
}

/* 正负号切换按钮 */
.score-sign-toggle {
  width: 80%;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #273444;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: #94A3B8;
  cursor: pointer;
  margin-bottom: 8rpx;
  transition: all 0.15s;
}

.score-sign-toggle:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.score-sign-toggle.positive {
  color: #10B981;
  background-color: rgba(16, 185, 129, 0.12);
}

.score-sign-toggle.negative {
  color: #EF4444;
  background-color: rgba(239, 68, 68, 0.12);
}

/* 总分行 */
.total-row {
  background-color: #292521;
}

.total-cell {
  width: 160rpx;
  min-width: 160rpx;
  max-width: 160rpx;
  flex-shrink: 0;
  flex-grow: 0;
  border-right: 1rpx solid #334155;
}

.total-cell:last-child {
  border-right: none;
}

.total-cell-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.rank-badge {
  font-size: 28rpx;
  line-height: 1;
}

.total-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #F1F5F9;
}

.total-value.positive {
  color: #10B981;
}

.total-value.negative {
  color: #EF4444;
}
/* ====================== 表格优化结束 ====================== */

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
  animation: pulse 1.5s ease-in-out infinite;
  color: #94A3B8;
}

.loading-text {
  font-size: 28rpx;
  color: #94A3B8;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  color: #94A3B8;
}

.empty-text {
  font-size: 28rpx;
  color: #94A3B8;
  margin-bottom: 20rpx;
}

/* 操作按钮区域 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  /* 商务底部栏 */
  background-color: #1E293B;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.2);
  z-index: 100;
}

.action-row {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  background-color: #273444;
  color: #F1F5F9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.action-btn:active {
  background-color: #334155;
}

.add-round-btn {
  background-color: #2563EB;
  color: #ffffff;
}

.add-round-btn:active {
  background-color: #1D4ED8;
}

.add-player-btn {
  background-color: #3B82F6;
  color: #ffffff;
}

.add-player-btn:active {
  background-color: #2563EB;
}

.reset-btn {
  background-color: #EF4444;
  color: #ffffff;
}

.reset-btn:active {
  background-color: #DC2626;
}

.remove-round-btn {
  background-color: #F59E0B;
  color: #ffffff;
}

.remove-round-btn:active {
  background-color: #D97706;
}

.btn-icon {
  font-size: 36rpx;
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
  padding: 40rpx;
}

.modal-content {
  width: 100%;
  max-width: 500rpx;
  padding: 0;
  background-color: #1E293B;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.3);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #F1F5F9;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  color: #94A3B8;
  font-size: 36rpx;
  padding: 0;
  line-height: 1;
}

.modal-body {
  padding: 0 32rpx 32rpx;
}

.edit-input {
  width: 100%;
  height: 88rpx;
  background-color: #273444;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #F1F5F9;
  border: none;
  outline: none;
}

/* 分数编辑包装器 */
.score-edit-wrapper {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 正负号按钮 */
.score-sign-btns {
  display: flex;
  gap: 16rpx;
}

.sign-btn {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #273444;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #94A3B8;
  border: none;
}

.sign-btn.active {
  background-color: #2563EB;
  color: #ffffff;
}

/* 分数输入框 */
.score-input {
  width: 100%;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx 32rpx;
}

.modal-footer button {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn-secondary {
  background-color: #273444;
  color: #F1F5F9;
}

.btn-primary {
  background-color: #2563EB;
  color: #ffffff;
}