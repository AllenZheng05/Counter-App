/* pages/create/create.wxss */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 40rpx;
  background-color: #f5f5f5;
}

/* Header 区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 60rpx;
}

.icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999999;
}

/* 表单区域 */
.form-section {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.char-count {
  font-size: 24rpx;
  color: #999999;
  text-align: right;
  margin-top: 8rpx;
}

/* 选择器样式 */
.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.picker-display text {
  font-size: 32rpx;
  color: #1a1a2e;
}

.picker-arrow {
  font-size: 36rpx;
  color: #cccccc !important;
}

/* 操作区域 */
.action-section {
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}

.btn-create {
  width: 100%;
  height: 100rpx;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 16rpx;
}

/* 提示文字 */
.tips {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 32rpx;
  background-color: #f0f4ff;
  border-radius: 16rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}