/* pages/index/index.wxss */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 40rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
}

/* Header 区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 用户信息区域 */
.user-section {
  margin-bottom: 40rpx;
}

/* 初始设置区域 */
.setup-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
  gap: 28rpx;
}

.setup-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.avatar-picker-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  background: none;
  border: none;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.setup-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #1a1a2e;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  border: 4rpx dashed #cccccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.avatar-placeholder-icon {
  font-size: 56rpx;
}

.avatar-placeholder-text {
  font-size: 20rpx;
  color: #999999;
}

.setup-nickname-input {
  width: 100%;
  height: 88rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1a1a2e;
  box-sizing: border-box;
  text-align: center;
}

.setup-confirm-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
}

/* 用户信息展示 */
.user-info {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #1a1a2e;
  margin-right: 24rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.welcome {
  font-size: 24rpx;
  color: #999999;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

/* 编辑用户信息按钮 */
.edit-profile-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  font-size: 32rpx;
  padding: 0;
  line-height: 1;
  margin-left: auto;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
  padding: 40rpx;
}

.modal-content {
  width: 100%;
  max-width: 560rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  color: #999999;
  font-size: 36rpx;
  padding: 0;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.edit-field {
  margin-bottom: 32rpx;
}

.edit-field:last-child {
  margin-bottom: 0;
}

.edit-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.edit-input {
  width: 100%;
  height: 88rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1a1a2e;
  box-sizing: border-box;
}

/* 头像编辑区域 */
.avatar-edit-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar-edit-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  padding: 0;
  background: none;
  border: none;
  overflow: hidden;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #1a1a2e;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999999;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx 32rpx;
}

.modal-footer button {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.btn-primary {
  background-color: #1a1a2e;
  color: #ffffff;
  border: none;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #666666;
  border: none;
}

/* 功能按钮区域 */
.action-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.action-card {
  display: flex;
  align-items: center;
  padding: 36rpx 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.2s;
}

.action-card:active {
  transform: scale(0.98);
}

.action-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.action-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.action-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #999999;
}

.action-arrow {
  font-size: 48rpx;
  color: #cccccc;
  margin-left: 16rpx;
}

/* 返回房间按钮样式 */
.return-card {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
}

.return-card .action-title,
.return-card .action-icon {
  color: #ffffff;
}

.return-card .action-desc {
  color: rgba(255, 255, 255, 0.8);
}

.return-card .action-arrow {
  color: rgba(255, 255, 255, 0.7);
}

/* 底部说明 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 8rpx;
}