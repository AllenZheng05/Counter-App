/* pages/index/index.wxss */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 40rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
}

/* Header 区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 用户信息区域 */
.user-section {
  margin-bottom: 40rpx;
}

.user-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.prompt-text {
  font-size: 28rpx;
  color: #666666;
}

/* 用户信息展示 */
.user-info {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #1a1a2e;
  margin-right: 24rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.welcome {
  font-size: 24rpx;
  color: #999999;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

/* 返回房间区域 */
.return-section {
  margin-bottom: 24rpx;
}

.return-card {
  display: flex;
  align-items: center;
  padding: 36rpx 24rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
  transition: transform 0.2s;
}

.return-card:active {
  transform: scale(0.98);
}

.return-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.return-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.return-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.return-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.return-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-left: 16rpx;
}

/* 功能按钮区域 */
.action-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.action-card {
  display: flex;
  align-items: center;
  padding: 36rpx 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.2s;
}

.action-card:active {
  transform: scale(0.98);
}

.action-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.action-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.action-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #999999;
}

.action-arrow {
  font-size: 48rpx;
  color: #cccccc;
  margin-left: 16rpx;
}

/* 底部说明 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 8rpx;
}