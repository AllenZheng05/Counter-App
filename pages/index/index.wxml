<!--pages/index/index.wxml-->
<view class="container">
  <!-- Logo和标题区域 -->
  <view class="header">
    <view class="logo">🃏</view>
    <view class="title">开心记分器</view>
    <view class="subtitle">斗地主 · 红五 · 掼蛋</view>
  </view>

  <!-- 用户信息区域 -->
  <view class="user-section card" wx:if="{{!hasUserInfo}}">
    <view class="setup-profile">
      <text class="setup-title">设置昵称和头像</text>

      <button class="avatar-picker-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{setupAvatarUrl}}" class="setup-avatar" src="{{setupAvatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="avatar-placeholder">
          <text class="avatar-placeholder-icon">👤</text>
          <text class="avatar-placeholder-text">点击选择头像</text>
        </view>
      </button>

      <input
        class="setup-nickname-input"
        type="nickname"
        placeholder="点击填入微信昵称"
        value="{{setupNickName}}"
        bindinput="onSetupNickNameInput"
        maxlength="20"
      />

      <button class="btn-primary setup-confirm-btn" bindtap="confirmSetup">开始记分</button>
    </view>
  </view>

  <view class="user-section card" wx:if="{{hasUserInfo}}">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="welcome">欢迎回来</text>
        <text class="nickname">{{userInfo.nickName}}</text>
      </view>
      <button class="edit-profile-btn" bindtap="showEditProfile">
        ✏️
      </button>
    </view>
  </view>

  <!-- 主要功能按钮 -->
  <view class="action-section" wx:if="{{hasUserInfo}}">
    <view class="action-card card" bindtap="goToCreate">
      <view class="action-icon">➕</view>
      <view class="action-text">
        <text class="action-title">创建房间</text>
        <text class="action-desc">创建新房间，邀请好友加入</text>
      </view>
      <view class="action-arrow">›</view>
    </view>

    <!-- 如果已在房间中，显示返回房间按钮；否则显示加入房间按钮 -->
    <view class="action-card card return-card" wx:if="{{showReturnRoom}}" bindtap="returnToRoom">
      <view class="action-icon">↩️</view>
      <view class="action-text">
        <text class="action-title">返回房间</text>
        <text class="action-desc">继续 {{returnRoomInfo.roomName}} 的计分</text>
      </view>
      <view class="action-arrow">›</view>
    </view>

    <view class="action-card card" wx:else bindtap="goToJoin">
      <view class="action-icon">🚪</view>
      <view class="action-text">
        <text class="action-title">加入房间</text>
        <text class="action-desc">输入邀请码，加入好友的房间</text>
      </view>
      <view class="action-arrow">›</view>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="footer">
    <text class="footer-text">适用于多种纸牌的通用计分工具</text>
    <text class="footer-text">支持实时同步，多人协作记分</text>
  </view>

  <!-- 编辑用户信息弹窗 -->
  <view class="modal-overlay" wx:if="{{showEditProfileModal}}" bindtap="hideEditProfile">
    <view class="modal-content card" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">修改个人信息</text>
        <button class="close-btn" bindtap="hideEditProfile">✕</button>
      </view>

      <view class="modal-body">
        <view class="edit-field">
          <text class="edit-label">昵称</text>
          <input 
            class="edit-input" 
            type="text"
            placeholder="请输入昵称"
            value="{{editNickName}}"
            bindinput="onNickNameInput"
            maxlength="20"
          />
        </view>
        <view class="edit-field">
          <text class="edit-label">头像</text>
          <view class="avatar-edit-section">
            <button class="avatar-edit-btn" open-type="chooseAvatar" bindchooseavatar="onEditChooseAvatar">
              <image class="avatar-preview" src="{{editAvatarUrl}}" mode="aspectFill"></image>
            </button>
            <text class="avatar-tip">点击更换头像</text>
          </view>
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn-secondary" bindtap="hideEditProfile">取消</button>
        <button class="btn-primary" bindtap="saveProfile">保存</button>
      </view>
    </view>
  </view>
</view>
